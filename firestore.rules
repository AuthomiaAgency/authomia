rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // AppData Collection (where most of the app's data lives)
    match /appData/{collectionId} {
      // Publicly readable collections (needed for the website to display content)
      allow read: if collectionId in ['publications', 'publicationGroups', 'authors', 'partners', 'surveys', 'materials'];
      
      // Collections that contain sensitive data require authentication to read
      allow read: if collectionId in ['team', 'actionLogs', 'applications'] && isAuthenticated();

      // Publicly writable collections (for survey responses and material leads)
      // We allow unauthenticated users to update, but ONLY if they are not reducing the number of items
      // This prevents malicious users from deleting all surveys or materials
      allow update: if collectionId in ['surveys', 'materials'] 
                    && request.resource.data.items.size() >= resource.data.items.size();

      // All other writes (create, update, delete) require authentication
      allow write: if isAuthenticated();
    }

    // Writer Applications (separate collection)
    match /writer_applications/{appId} {
      allow create: if true; // Anyone can submit an application
      allow read, update, delete: if isAuthenticated(); // Only team members can manage them
    }
  }
}
